# Server-side fallback keys - used when the user hasn't entered their own
# keys in the Settings panel.

# Groq is the fallback LLM provider when no Claude key is provided by the user.
GROQ_API_KEY=

# Optional: if you want a server-side InsightSentry fallback (not required;
# yfinance is used if neither this nor a user-provided key is present).
INSIGHTSENTRY_API_KEY=

# Optional: lets the developer test the Claude path without entering a key
# in the UI every time. NOT used as a fallback for end users - the app
# always prefers a user-entered key, then Groq.
ANTHROPIC_API_KEY=
